# Frontend environment — copy to .env (gitignored) and fill in.
# Vite only exposes vars prefixed with VITE_ to the client.

# Base URL of the Anchor backend. For local dev this is the FastAPI server;
# in production it's the Cloud Run service URL.
#   local:      http://localhost:8080
#   cloud run:  https://anchor-backend-XXXXXXXX.<region>.run.app
VITE_API_URL=http://localhost:8080
