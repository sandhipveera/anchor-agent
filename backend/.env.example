# Anchor backend environment — copy to .env (gitignored) and fill in.
# In production these are Cloud Run env vars / Secret Manager, not a file.
#
# NONE of these are needed for the Phase-0 /healthz shell. They are listed so
# you know exactly what to paste once each dependency is live.

# ---- Service ----
SERVICE_NAME=anchor
ENVIRONMENT=dev                      # dev | staging | prod

# ---- Elastic Serverless (fill in once the trial deployment is live) ----
# From the Elastic Cloud console after creating a Serverless project:
#   - Endpoint URL:  the project's Elasticsearch endpoint
#       (looks like https://<project>.es.<region>.<csp>.elastic.cloud:443)
#   - API key:       create under the project → "API keys" (store the ENCODED key)
#   - Cloud ID:      optional; shown on the deployment page. The Python client
#                    can use cloud_id OR endpoint URL — endpoint URL is preferred
#                    for Serverless.
ELASTIC_ENDPOINT_URL=
ELASTIC_API_KEY=
ELASTIC_CLOUD_ID=

# ---- Google Cloud ----
GCP_PROJECT=                         # the project Cloud Run + Firestore live in

# ---- Auth (Google Sign-In; not wired yet) ----
GOOGLE_CLIENT_ID=                    # OAuth 2.0 Web client ID, for ID-token verification

# ---- CORS ----
# Comma-separated allowed origins. "*" is acceptable ONLY for the content-free
# /healthz shell; set to the real PWA origin(s) before any data endpoint ships.
CORS_ALLOW_ORIGINS=*
